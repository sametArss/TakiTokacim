@{
    ViewData["Title"] = "Kayıt Ol";
}
<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card border-0 shadow-lg p-4">
            <h2 class="fw-bold mb-4 text-center" style="color:#e67e22;">Kayıt Ol</h2>
            <form>
                <div class="mb-3">
                    <label class="form-label">Ad Soyad</label>
                    <input type="text" class="form-control" placeholder="Adınız Soyadınız">
                </div>
                <div class="mb-3">
                    <label class="form-label">E-posta</label>
                    <input type="email" class="form-control" placeholder="E-posta adresiniz">
                </div>
                <div class="mb-3">
                    <label class="form-label">Şifre</label>
                    <input type="password" class="form-control" placeholder="Şifreniz">
                </div>
                <button type="submit" class="btn btn-warning w-100" style="background:#e67e22; border:none;">Kayıt Ol</button>
            </form>
            <div class="mt-3 text-center">
                <span>Zaten hesabınız var mı? <a href="/Account/Login" style="color:#e67e22;">Giriş Yap</a></span>
            </div>
        </div>
    </div>
</div> 