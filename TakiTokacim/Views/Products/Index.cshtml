@model List<dynamic>
@{
    ViewData["Title"] = "Ürünler";
    var categories = new List<string> { "Yüzükler", "Kolyeler", "Bileklikler", "Küpeler" };
    var selected = ViewBag.SelectedCategory as string;
}
<div class="row mb-4">
    <div class="col-12 text-center">
        <h1 class="fw-bold" style="color:#e67e22;">Ürün Kataloğu</h1>
        <div class="btn-group mt-3" role="group">
            <a href="/Products" class="btn btn-outline-warning @(string.IsNullOrEmpty(selected) ? "active" : "")">Tümü</a>
            @foreach (var cat in categories)
            {
                <a href="/Products?category=@cat" class="btn btn-outline-warning @(selected == cat ? "active" : "")">@cat</a>
            }
        </div>
    </div>
</div>
<div class="row g-4">
    @foreach (var product in Model)
    {
        <div class="col-md-3">
            <div class="card h-100 border-0 shadow-sm">
                <img src="@product.Image" class="card-img-top" alt="@product.Name">
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title">@product.Name</h5>
                    <p class="card-text text-muted">@product.Category</p>
                    <div class="mt-auto">
                        <div class="fw-bold mb-2" style="color:#e67e22; font-size:1.2rem;">@product.Price TL</div>
                        <a href="/Products/Details/@product.Id" class="btn btn-outline-warning w-100">İncele</a>
                    </div>
                </div>
            </div>
        </div>
    }
</div> 